[sub_resource type="GDScript" id="GDScript_0tnpc"]
script/source = "extends Node2D

@onready var score_label: Label = %ScoreLabel
@onready var player: CharacterBody2D = $Player
@onready var welcome: Label = $Labels/Welcome
@onready var info_text: Label = $Labels/InfoText
@onready var jump_text: Label = $Labels/JumpText

var textIndex= 0
var startMessages = [
	\"Tu te trouve actuellement dans un monde déchu, peuplé par les slimes.\",
	\"Les slimes sont des créatures maléfiques : évite-les à tout prix !\",
	\"Il est cependant possible de les tuer...\",
	\"...mais je ne sais plus comment ! (oups...)\",
	\"Pour accomplir ta quête, il te faudra arriver au bout de ce monde.\",
	\"Bonne chance !\"
]

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	welcome.text = \"Bienvenue, cher Voyageur\"


func _input(event):
	if event.is_action_pressed(\"Interact\"): # touche E via Input Map
		info_text.hide()
		if textIndex < startMessages.size():
			welcome.text = startMessages[textIndex]
			textIndex += 1
	if event.is_action_pressed(\"ui_accept\"):
		jump_text.hide()
	

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	score_label.global_position = player.global_position + Vector2(-30, -50)


func _on_timer_timeout() -> void:
	pass # Replace with function body.
"

